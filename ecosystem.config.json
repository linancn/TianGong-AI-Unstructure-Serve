{
  "apps": [
    {
      "name": "unstructured-gunicorn",
      "cwd": ".",
      "script": ".venv/bin/gunicorn",
      "interpreter": "none",
      "args": "-k uvicorn.workers.UvicornWorker -w 4 -b 0.0.0.0:7770 --timeout 300 --graceful-timeout 60 --keep-alive 30 --max-requests 500 --max-requests-jitter 50 src.main:app",
      "env": {
        "MINERU_MODEL_SOURCE": "modelscope",
        "MINERU_TASK_HARD_TIMEOUT_SECONDS": "1800",
        "MINERU_DEFAULT_HARD_TIMEOUT_SECONDS": "1800",
        "MINERU_IMAGES_HARD_TIMEOUT_SECONDS": "1800",
        "VISION_PROVIDER": "vllm",
        "VISION_PROVIDER_CHOICES": "vllm",
        "VISION_MODEL": "Qwen/Qwen3.5-397B-A17B-GPTQ-Int4",
        "MINERU_SCI_HARD_TIMEOUT_SECONDS": "300",
        "MINERU_SCI_TIMEOUT_SECONDS": "110",
        "MINERU_OFFICE_CONVERT_TIMEOUT_SECONDS": "600",
        "MINERU_PROCESSING_WINDOW_SIZE": "512"
      },
      "out_file": "gunicorn.log",
      "error_file": "gunicorn.log",
      "time": true
    }
  ]
}
